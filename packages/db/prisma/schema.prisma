// Database-backed sessions instead of next-auth's Credentials+JWT default:
// plan.md section 5 requires that an admin can revoke a session server-side
// (role change, deactivation), which next-auth's Credentials provider can't
// do with database sessions — so auth is implemented directly against this
// schema (see apps/main/src/lib/auth) rather than through next-auth.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  coach
  player
  referee
}

enum Capability {
  teamindeling
  statistieken
}

enum AuditAction {
  role_changed
  club_changed
  capabilities_changed
  password_reset
  user_deactivated
  user_activated
  user_deleted
  user_invited
  app_config_changed
  maintenance_mode_changed
  club_created
  club_updated
  club_deleted
}

model Club {
  id        String   @id @default(cuid())
  naam      String
  refId     String?  @unique

  latitude  Float?
  longitude Float?

  addressName            String?
  addressType            String?
  addressDescription     String?
  streetName             String?
  addressNumber          Int?
  addressNumberAppendix  String?
  postalCode             String?
  city                   String?
  country                String?
  countryCode            String?

  veldPoolName String?
  veldPoolId   Int?
  zaalPoolName String?
  zaalPoolId   Int?

  clusterId   String?
  clusterName String?
  regioId     Int?
  regioName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  naam          String?
  passwordHash  String
  role          Role         @default(player)
  capabilities  Capability[] @default([])
  clubId        String?
  club          Club?        @relation(fields: [clubId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deactivatedAt DateTime?
  emailVerifiedAt DateTime?
  consentedAt     DateTime?

  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogsAsActor        AuditLog[]               @relation("AuditLogActor")
  auditLogsAsTarget       AuditLog[]               @relation("AuditLogTarget")

  @@index([clubId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// Fixed-window rate limiting, Postgres-backed instead of Redis/Upstash to
// avoid a new external dependency (see the DB-backed-sessions rationale at
// the top of this file — same philosophy). key is e.g. "login:ip:1.2.3.4" or
// "login:email:foo@bar.com"; windowStart buckets requests into fixed windows.
model RateLimitAttempt {
  key         String
  windowStart DateTime
  count       Int      @default(1)

  @@id([key, windowStart])
  @@index([windowStart])
}

// One row per Capability (see enum above) — homepage (apps/main) renders the
// "Apps" grid from this table, admin settings page manages it. Rows are
// created lazily (upserted) the first time an admin fetches the list, so
// adding a new value to the Capability enum doesn't require a data migration.
model AppConfig {
  capability Capability @id
  title      String
  imageUrl   String?
  visible    Boolean    @default(true)
  updatedAt  DateTime   @updatedAt
}

// Single-row platform-wide settings. Always read/written through id
// "singleton" — see apps/main's require-settings-style helper — so there's
// never more than one row to reconcile.
model PlatformSettings {
  id              String   @id @default("singleton")
  maintenanceMode Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id            String      @id @default(cuid())
  // Nullable + SetNull: a user can now be hard-deleted (see "verwijderen" in
  // the admin UI), and the audit trail must survive that rather than block
  // the delete or vanish with it.
  actorId       String?
  actor         User?       @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  action        AuditAction
  targetUserId  String?
  targetUser    User?       @relation("AuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  metadata      Json        @default("{}")
  createdAt     DateTime    @default(now())

  @@index([actorId])
  @@index([targetUserId])
}

# apps/teamplanner has no DATABASE_URL — it only talks to the main API (see docs/plan.md section 10).
# In production this MUST be the canonical www host, not the bare domain: the
# bare domain 308-redirects to www, and fetch() drops the Cookie header on
# cross-origin redirects, which silently breaks getCurrentUser().
MAIN_APP_URL="http://localhost:3000"

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable GA.
NEXT_PUBLIC_GA_ID=""
